<!doctype html>
<html lang="{{ site.lang }}">
<head>
  {% include metadata.liquid %}
  <link rel="shortcut icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>{{ site.icon }}</text></svg>">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:         #1c1c1d;
      --border:     #424246;
      --text:       #e2e2e2;
      --dim:        #828282;
      --faint:      #2a2a2b;
      --accent:     #2698ba;
      --accent-dim: #1a6880;
    }

    html, body {
      min-height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: 'Monaco', 'Menlo', 'Consolas', 'Courier New', monospace;
      font-size: 14px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    body {
      display: flex;
      justify-content: center;
      padding: 48px 24px;
      min-height: 100vh;
    }

    main {
      width: 100%;
      max-width: 640px;
    }

    .breadcrumb {
      font-size: 12px;
      color: var(--dim);
      margin-bottom: 32px;
    }
    .breadcrumb a {
      color: var(--accent);
      text-decoration: none;
    }
    .breadcrumb a:hover { text-decoration: underline; }
    .breadcrumb span { margin: 0 6px; }

    h1 {
      font-size: 18px;
      font-weight: bold;
      color: var(--accent);
      margin-bottom: 24px;
    }

    .content { color: var(--text); }

    .content p  { margin-bottom: 16px; color: var(--dim); font-style: italic; }

    .content ul {
      list-style: none;
      margin-bottom: 16px;
    }
    .content ul li {
      padding: 10px 0;
      border-bottom: 1px solid var(--faint);
      color: var(--text);
    }
    .content ul li:first-child { border-top: 1px solid var(--faint); }

    .content ul li strong { color: var(--accent); }

    .content a {
      color: var(--accent);
      text-decoration: underline;
      text-decoration-color: var(--accent-dim);
      text-underline-offset: 2px;
    }
    .content a:hover { color: #fff; }

    hr {
      border: none;
      border-top: 1px solid var(--faint);
      margin: 28px 0;
    }
  </style>
</head>
<body>
  <main>
    <div class="breadcrumb">
      <a href="/">~/</a><span>›</span>{{ page.title }}
    </div>
    <h1>{{ page.title }}/</h1>
    <div class="content">
      {{ content }}
    </div>
  </main>
</body>
</html>
