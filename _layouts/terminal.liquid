<!doctype html>
<html lang="{{ site.lang }}">
<head>
  {% include metadata.liquid %}
  <link rel="shortcut icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>{{ site.icon }}</text></svg>">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* blog dark theme palette */
    :root {
      --bg:         #1c1c1d;
      --chrome-bg:  #111112;
      --border:     #424246;
      --text:       #e2e2e2;
      --dim:        #828282;
      --faint:      #2a2a2b;
      --accent:     #2698ba;   /* cyan — blog dark theme color */
      --accent-dim: #1a6880;
      --error:      #ff3636;
      --cursor:     #2698ba;
    }

    html, body {
      min-height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: 'Monaco', 'Menlo', 'Consolas', 'Courier New', monospace;
      font-size: 14px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    body {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
      min-height: 100vh;
    }

    a {
      color: var(--accent);
      text-decoration: underline;
      text-decoration-color: var(--accent-dim);
      text-underline-offset: 2px;
      transition: color 0.15s;
    }
    a:hover { color: #fff; text-decoration-color: var(--accent); }

    /* ── Toggle button ── */
    .view-toggle {
      position: fixed;
      top: 14px;
      right: 14px;
      background: var(--chrome-bg);
      border: 1px solid var(--border);
      color: var(--dim);
      font-family: inherit;
      font-size: 11px;
      padding: 5px 10px;
      border-radius: 4px;
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s;
      z-index: 100;
    }
    .view-toggle:hover { color: var(--text); border-color: var(--dim); }

    /* ════════════════════════════════
       TERMINAL VIEW
    ════════════════════════════════ */
    #terminal-view {
      width: 100%;
      max-width: 680px;
    }

    .terminal-window {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    }

    .title-bar {
      background: var(--chrome-bg);
      border-bottom: 1px solid var(--border);
      padding: 10px 14px;
      display: flex;
      align-items: center;
      gap: 8px;
      user-select: none;
    }
    .dot { width: 12px; height: 12px; border-radius: 50%; }
    .dot-red    { background: #ff5f57; }
    .dot-yellow { background: #febc2e; }
    .dot-green  { background: #28c840; }
    .title-label {
      margin-left: 8px;
      font-size: 12px;
      color: var(--dim);
      letter-spacing: 0.02em;
    }

    .terminal-body {
      background: var(--bg);
      padding: 24px;
      cursor: text;
    }

    .t-block { margin-bottom: 18px; }

    .prompt-line { color: var(--dim); margin-bottom: 4px; }
    .prompt-line .cmd-char { color: var(--accent); }

    .output-line { color: var(--text); }
    .output-line.bright { color: var(--accent); font-weight: bold; }

    .t-divider {
      border: none;
      border-top: 1px solid var(--faint);
      margin: 18px 0;
    }

    #history-area { margin-top: 8px; }
    .hist-entry   { margin-top: 16px; }
    .hist-prompt  { color: var(--dim); }
    .hist-output  { margin-top: 4px; }
    .hist-error   { color: var(--error); }

    .input-line {
      display: flex;
      align-items: center;
      margin-top: 18px;
      gap: 6px;
    }
    .input-ps1 { color: var(--dim); white-space: nowrap; }
    .input-wrapper { flex: 1; display: flex; align-items: center; }

    #cmd-input {
      background: transparent;
      border: none;
      outline: none;
      color: var(--text);
      font-family: inherit;
      font-size: inherit;
      line-height: inherit;
      caret-color: transparent;
      width: 100%;
    }

    #t-cursor {
      display: inline-block;
      width: 8px;
      height: 1em;
      background: var(--cursor);
      vertical-align: text-bottom;
      animation: blink 1s steps(1) infinite;
      flex-shrink: 0;
    }
    @keyframes blink {
      0%, 49% { opacity: 1; }
      50%, 100% { opacity: 0; }
    }

    /* ════════════════════════════════
       SIMPLE VIEW
    ════════════════════════════════ */
    #simple-view {
      width: 100%;
      max-width: 540px;
      padding: 16px 0;
    }

    .s-name {
      font-size: 20px;
      font-weight: bold;
      color: var(--accent);
      margin-bottom: 4px;
    }
    .s-subtitle { font-size: 13px; color: var(--dim); margin-bottom: 22px; }
    .s-desc     { color: var(--text); margin-bottom: 28px; line-height: 1.7; }

    .s-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--dim);
      margin-bottom: 10px;
    }
    .s-links {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 20px;
      margin-bottom: 28px;
    }
    .s-divider {
      border: none;
      border-top: 1px solid var(--faint);
      margin: 22px 0;
    }
  </style>
</head>
<body>

  <button class="view-toggle" id="view-toggle" onclick="toggleView()" aria-label="Switch view">
    simple view
  </button>

  <!-- ═══════════ TERMINAL VIEW ═══════════ -->
  <div id="terminal-view">
    <div class="terminal-window">

      <div class="title-bar">
        <div class="dot dot-red"></div>
        <div class="dot dot-yellow"></div>
        <div class="dot dot-green"></div>
        <span class="title-label">{{ site.first_name | downcase }}@home — bash</span>
      </div>

      <div class="terminal-body" id="terminal-body">

        <div class="t-block">
          <div class="prompt-line"><span class="cmd-char">$</span> whoami</div>
          <div class="output-line bright">{{ site.first_name }} {{ site.last_name }}</div>
        </div>

        <div class="t-block">
          <div class="prompt-line"><span class="cmd-char">$</span> echo $ABOUT</div>
          <div class="output-line">"{{ site.description | strip }}"</div>
        </div>

        <hr class="t-divider">

        <div class="t-block">
          <div class="prompt-line"><span class="cmd-char">$</span> ls ~/</div>
          <div class="output-line">📂 <a href="/blog/">blog/</a></div>
          <div class="output-line">📂 <a href="/interests/">interests/</a></div>
        </div>

        <hr class="t-divider">

        <div class="t-block">
          <div class="prompt-line"><span class="cmd-char">$</span> cat ~/.social</div>
          <div class="output-line">
            <a href="https://github.com/{{ site.data.socials.github_username }}" target="_blank" rel="noopener noreferrer">GitHub</a>
            &nbsp;·&nbsp;
            <a href="https://x.com/{{ site.data.socials.x_username }}" target="_blank" rel="noopener noreferrer">X</a>
            &nbsp;·&nbsp;
            <a href="https://linkedin.com/in/{{ site.data.socials.linkedin_username }}" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            &nbsp;·&nbsp;
            <a href="/feed.xml">RSS</a>
          </div>
        </div>

        <hr class="t-divider">

        <div id="history-area"></div>

        <div class="input-line">
          <span class="input-ps1">{{ site.first_name | downcase }}@home:~$</span>
          <div class="input-wrapper">
            <input id="cmd-input" type="text" autocomplete="off" spellcheck="false" aria-label="Terminal input">
            <span id="t-cursor"></span>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- ═══════════ SIMPLE VIEW ═══════════ -->
  <div id="simple-view" style="display:none">

    <div class="s-name">{{ site.first_name }} {{ site.last_name }}</div>
    <div class="s-subtitle">{{ page.subtitle }}</div>
    <div class="s-desc">{{ site.description | strip }}</div>

    <div class="s-label">pages</div>
    <div class="s-links">
      <a href="/blog/">blog/</a>
      <a href="/interests/">interests/</a>
    </div>

    <hr class="s-divider">

    <div class="s-label">links</div>
    <div class="s-links">
      <a href="https://github.com/{{ site.data.socials.github_username }}" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://x.com/{{ site.data.socials.x_username }}" target="_blank" rel="noopener noreferrer">X</a>
      <a href="https://linkedin.com/in/{{ site.data.socials.linkedin_username }}" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="/feed.xml">RSS</a>
    </div>

  </div>

  <script>
  (function () {
    var PREF_KEY  = 'view-pref';
    var btn       = document.getElementById('view-toggle');
    var termView  = document.getElementById('terminal-view');
    var simpView  = document.getElementById('simple-view');

    /* ── terminal DOM refs — declared BEFORE applyView is called ── */
    var cmdInput   = document.getElementById('cmd-input');
    var historyDiv = document.getElementById('history-area');
    var blogUrl    = '/blog/';
    var interestsUrl = '/interests/';

    var COMMANDS = ['help', 'ls', 'cd', 'cat', 'echo', 'clear', 'whoami'];
    var DIRS     = ['blog', 'interests'];
    var FILES    = ['~/.social'];

    var cmdHistory = [];
    var histIdx    = -1;
    var cmdCount   = 0;

    function focusInput() {
      if (cmdInput) cmdInput.focus();
    }

    /* ── view switching ── */
    function applyView(simple) {
      if (simple) {
        termView.style.display = 'none';
        simpView.style.display = '';
        btn.textContent = 'terminal view';
        document.body.onclick = null;
      } else {
        simpView.style.display = 'none';
        termView.style.display = '';
        btn.textContent = 'simple view';
        document.body.onclick = focusInput;
        focusInput();
      }
    }

    window.toggleView = function () {
      var next = simpView.style.display === 'none' ? false : true;
      /* next = true → go to simple; next = false → go to terminal */
      localStorage.setItem(PREF_KEY, next ? 'terminal' : 'simple');
      applyView(!next);
    };

    window.toggleView = function () {
      var goSimple = termView.style.display !== 'none'; /* currently terminal → go simple */
      localStorage.setItem(PREF_KEY, goSimple ? 'simple' : 'terminal');
      applyView(goSimple);
    };

    var stored      = localStorage.getItem(PREF_KEY);
    var mobile      = window.matchMedia('(max-width: 640px)').matches;
    var startSimple = stored ? (stored === 'simple') : mobile;
    applyView(startSimple);

    /* ── Cmd+K / Ctrl+K clears screen ── */
    document.addEventListener('keydown', function (e) {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        if (termView.style.display !== 'none') {
          e.preventDefault();
          historyDiv.innerHTML = '';
          cmdInput.value = '';
          focusInput();
        }
      }
    });

    /* ── terminal input ── */
    cmdInput.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        run(cmdInput.value.trim());
        histIdx = -1;
        cmdInput.value = '';
      } else if (e.key === 'Tab') {
        e.preventDefault();
        autocomplete(cmdInput.value);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (histIdx < cmdHistory.length - 1) {
          histIdx++;
          cmdInput.value = cmdHistory[cmdHistory.length - 1 - histIdx];
        }
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (histIdx > 0) {
          histIdx--;
          cmdInput.value = cmdHistory[cmdHistory.length - 1 - histIdx];
        } else { histIdx = -1; cmdInput.value = ''; }
      }
    });

    function autocomplete(val) {
      var parts = val.split(/\s+/);
      if (parts.length === 1) {
        var m = COMMANDS.filter(function(c) { return c.indexOf(parts[0]) === 0 && c !== parts[0]; });
        if (m.length === 1) cmdInput.value = m[0] + ' ';
      } else {
        var cmd = parts[0].toLowerCase();
        var arg = parts.slice(1).join(' ');
        if (cmd === 'cd') {
          var m = DIRS.filter(function(d) { return d.indexOf(arg) === 0 && d !== arg; });
          if (m.length === 1) cmdInput.value = cmd + ' ' + m[0];
        } else if (cmd === 'cat') {
          var m = FILES.filter(function(f) { return f.indexOf(arg) === 0 && f !== arg; });
          if (m.length === 1) cmdInput.value = cmd + ' ' + m[0];
        }
      }
    }

    function run(raw) {
      if (!raw) return;
      cmdHistory.push(raw);
      var parts = raw.split(/\s+/);
      var cmd   = parts[0].toLowerCase();
      if (cmd === 'clear') { historyDiv.innerHTML = ''; return; }
      appendEntry(raw, buildOutput(cmd, parts));
      if (cmd === 'cd') {
        var dir = (parts[1] || '').replace(/\//g, '').toLowerCase();
        if (dir === 'blog')      setTimeout(function() { window.location.href = blogUrl; }, 300);
        if (dir === 'interests') setTimeout(function() { window.location.href = interestsUrl; }, 300);
      }
    }

    function buildOutput(cmd, parts) {
      switch (cmd) {
        case 'help':
          return lines([
            hi('help')          + '          — show this message',
            hi('ls')            + '            — list pages',
            hi('cd blog')       + '       — go to the blog',
            hi('cd interests')  + ' — go to interests',
            hi('cat ~/.social') + ' — show links',
            hi('whoami')        + '        — who is this',
            hi('echo &lt;text&gt;')   + '   — echo text back',
            hi('clear')         + '         — clear history',
          ]);
        case 'ls':
          return lines([
            '📂 <a href="' + blogUrl + '">blog/</a>',
            '📂 <a href="' + interestsUrl + '">interests/</a>',
          ]);
        case 'whoami':
          return lines(['{{ site.first_name }} {{ site.last_name }}']);
        case 'cd': {
          var dir = (parts[1] || '').replace(/\//g, '').toLowerCase();
          if (!dir) return err('cd: missing argument. try: cd blog');
          if (dir === 'blog')      return lines([hi('navigating to /blog/ ...')]);
          if (dir === 'interests') return lines([hi('navigating to /interests/ ...')]);
          return err('cd: no such directory: ' + esc(parts[1]));
        }
        case 'cat': {
          var file = parts.slice(1).join(' ');
          if (file === '~/.social') {
            return lines([
              '<a href="https://github.com/{{ site.data.socials.github_username }}" target="_blank" rel="noopener noreferrer">GitHub</a>'
              + ' &nbsp;·&nbsp; '
              + '<a href="https://x.com/{{ site.data.socials.x_username }}" target="_blank" rel="noopener noreferrer">X</a>'
              + ' &nbsp;·&nbsp; '
              + '<a href="https://linkedin.com/in/{{ site.data.socials.linkedin_username }}" target="_blank" rel="noopener noreferrer">LinkedIn</a>'
              + ' &nbsp;·&nbsp; '
              + '<a href="/feed.xml">RSS</a>'
            ]);
          }
          return err('cat: ' + (esc(file) || '(no file)') + ': No such file or directory');
        }
        case 'echo':
          return lines([esc(parts.slice(1).join(' '))]);
        default:
          return err(esc(cmd) + ': command not found. type ' + hi('help') + ' for commands.');
      }
    }

    function hi(s)    { return '<span style="color:var(--accent)">' + s + '</span>'; }
    function lines(a) { return a.map(function(l) { return '<div class="output-line">' + l + '</div>'; }).join(''); }
    function err(m)   { return '<div class="hist-error">' + m + '</div>'; }
    function esc(s)   { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    function appendEntry(cmd, outputHtml) {
      var div = document.createElement('div');
      div.className = 'hist-entry';
      div.innerHTML =
        '<div class="hist-prompt">{{ site.first_name | downcase }}@home:~$ ' + esc(cmd) + '</div>'
        + '<div class="hist-output">' + outputHtml + '</div>';
      historyDiv.appendChild(div);
      div.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  })();
  </script>

</body>
</html>
